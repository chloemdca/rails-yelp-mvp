<div class="container mt-5" style="max-width: 600px;">
  <% if @restaurant.errors.any? %>
  <div class="alert alert-danger">
    <% @restaurant.errors.full_messages.each do |msg| %>
      <p><%= msg %></p>
    <% end %>
  </div>
  <% end %>
  <h1 class="mb-4">Add a new restaurant</h1>
  <%= simple_form_for(@restaurant) do |f| %>
    <%= f.input :name %>
    <%= f.input :address %>
    <%= f.input :category, collection: ["french", "italian", "japanese", "chinese", "belgian"] %>
    <%= f.input :phone_number %>
    <%= f.submit "Create Restaurant", class: "btn btn-primary mt-2" %>
  <% end %>
  <%= link_to "Back to list", "/restaurants", class: "btn btn-primary mt-3" %>
</div>
