<div class="container mt-4">
  <h1 class="display-5 fw-bold mb-4">Restaurants</h1>

  <% @restaurants.each do |restaurant| %>
    <div class="d-flex align-items-center gap-3 p-3 mb-3 bg-white rounded shadow-sm">
      <%= link_to restaurant.name, "/restaurants/#{restaurant.id}", class: "text-primary text-decoration-none" %>
    </div>
  <% end %>

  <%= link_to "+ Add a new restaurant", "restaurants/new", class: "btn btn-primary mt-2" %>
</div>
