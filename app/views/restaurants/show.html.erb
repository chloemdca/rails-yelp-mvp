<div class="container mt-4">
  <h1 class="display-5 fw-bold mb-4"><%= @restaurant.name %></h1>
  <p class="text-muted mb-3">Category: <%= @restaurant.category %></p>
  <p class="text-muted mb-3">Address: <%= @restaurant.address %></p>
  <p class="text-muted mb-3">Phone number: <%= @restaurant.phone_number %></p>

  <h3>Reviews</h3>
  <% @restaurant.reviews.each do |review| %>
    <div class="card mb-3">
      <div class="card-body">
        <p class="mb-0 <%= review.rating <= 2 ? 'text-danger' : review.rating >= 4 ? 'text-success' : 'text-muted' %>">
          Rating: <%= review.rating %>/5
        </p>
        <p class="card-text"><%= review.content %></p>
      </div>
    </div>
  <% end %>
  <%= link_to "Back to list", "/restaurants", class: "btn btn-outline-secondary mt-1" %>
    <% if @review.errors.any? %>
    <div class="alert alert-danger">
      <% @review.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
    <% end %>
    <h3 class="mt-4 mb-2">Add a new review</h3>
    <%= simple_form_for([@restaurant, @review]) do |f| %>
      <%= f.input :rating %>
      <%= f.input :content %>
      <%= f.submit "Create Review", class: "btn btn-primary mt-2" %>
    <% end %>
  <%= link_to "Back to list", "/restaurants", class: "btn btn-primary mt-3" %>
</div>
