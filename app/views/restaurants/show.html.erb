<div class="container mt-4">
  <h1 class="display-5 fw-bold mb-4"><%= @restaurant.name %></h1>
  <p class="text-muted mb-3">Category: <%= @restaurant.category %></p>
  <p class="text-muted mb-3">Address: <%= @restaurant.address %></p>
  <p class="text-muted mb-3">Phone number: <%= @restaurant.phone_number %></p>

  <h3>Reviews</h3>
  <% @restaurant.reviews.each do |review| %>
    <div class="card mb-3">
      <div class="card-body">
        <p class="mb-0 <%= review.rating <= 2 ? 'text-danger' : review.rating >= 4 ? 'text-success' : 'text-muted' %>">
          Rating: <%= review.rating %>/5
        </p>
        <p class="card-text"><%= review.content %></p>
      </div>
    </div>
  <% end %>
  <%= link_to "Back to list", "/restaurants", class: "btn btn-outline-secondary mt-2" %>
  <%= link_to "Add a review", new_restaurant_review_path(@restaurant), class: "btn btn-outline-secondary mt-2" %>
</div>
